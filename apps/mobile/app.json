{
  "expo": {
    "name": "FlowradAI",
    "slug": "flowrad-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "flowrad",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#060A14",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#060A14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flowradai.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "FlowradAI uses your microphone to transcribe radiology findings via voice dictation."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060A14"
      },
      "package": "com.flowradai.mobile",
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow FlowradAI to access your microphone for voice dictation."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
