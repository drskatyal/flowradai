# Copy this file to .env.local and fill in the values before running `pnpm build:lite`
# These are BAKED INTO the HTML at build time (like NEXT_PUBLIC_ vars in Next.js).

# Your Clerk publishable key (pk_live_... or pk_test_...)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_

# Base URL of the Express API server (no trailing slash)
# On NHS networks this is the same backend that app.flowrad.ai uses
VITE_API_URL=https://api.flowrad.ai
